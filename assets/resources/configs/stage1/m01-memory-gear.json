  "interactions": [
    {
      "trigger": "drag:filter_red -> slot:entity_filter_socket",
      "effect": "highlight:tag:red | dim:tag:!red",
      "animation": "insert_filter"
    },
    {
      "trigger": "drag:filter_blue -> slot:entity_filter_socket",
      "effect": "highlight:tag:blue | dim:tag:!blue",
      "animation": "insert_filter"
    },
    {
      "trigger": "drag:filter_yellow -> slot:entity_filter_socket",
      "effect": "highlight:tag:yellow | dim:tag:!yellow",
      "animation": "insert_filter"
    },
    {
      "trigger": "drag:fragment -> slot:matching_slot",
      "condition": "fragment.color == activeFilter.color && fragment.color == slot.accepts.color && fragment.shape == slot.accepts.shape",
      "effect": "snap:fragment | stack:slot"
    },
    {
      "trigger": "drag:fragment -> slot:non_matching_slot",
      "condition": "fragment.color != slot.accepts.color || fragment.shape != slot.accepts.shape",
      "effect": "reject:fragment | pulse:target_slot"
    }
  ],
