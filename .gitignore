# MCP config (contains API keys)
.mcp.json

# Claude Code user-local overrides
.claude/settings.local.json

# Ephemeral session context (codex session IDs, etc.)
.context/
.codex/

# ralphex runtime state is local; keep only checked-in config and wrappers.
.ralphex/progress/
.ralphex/worktrees/
.ralphex/agents/
.ralphex/prompts/

node_modules/
dist/
coverage/
.DS_Store
.env
.env.*
*.pem
*.key

# Cocos Creator generated outputs
/library/
/temp/
/local/
/build/
/native/engine/android/**/*/assets

# Local editor/tooling extensions
/extensions/cocos-mcp-server/
/settings/mcp-server.json
/settings/tool-manager.json
/settings/v2/packages/information.json

# Cocos local editor profiles are machine-specific.
/profiles/*
!/profiles/v2/
/profiles/v2/*
!/profiles/v2/packages/
/profiles/v2/packages/*
